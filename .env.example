# Copy this file to ".env" and fill in your real values for LOCAL testing.
# .env is gitignored and must NEVER be committed.
#
# In GitHub Actions these are provided as repository Secrets instead of a file
# (Settings -> Secrets and variables -> Actions). See README.md.

# Brevo API key (used to actually send the email over HTTPS).
# Get it at https://app.brevo.com/settings/keys/api  (starts with "xkeysib-").
BREVO_API_KEY=xkeysib-your-key-here

# The verified Brevo sender address the alerts are sent FROM.
YAHOO_EMAIL=your-verified-sender@example.com

# Where alerts are sent TO. Separate multiple recipients with commas.
ALERT_EMAIL=you@example.com
